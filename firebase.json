{
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**",
      "**/.git/**",
      "package.json",
      "package-lock.json",
      "app-debug.apk",
      "*.exe",
      "*.dll",
      "*.bat"
    ],
    "rewrites": [
      {
        "source": "/serial",
        "destination": "/index.html"
      },
      {
        "source": "/videos",
        "destination": "/videos.html"
      },
      {
        "source": "/gallery",
        "destination": "/gallery.html"
      },
      {
        "source": "/heroes",
        "destination": "/heroes.html"
      },
      {
        "source": "/articles",
        "destination": "/articles.html"
      },
      {
        "source": "/soundtracks",
        "destination": "/soundtracks.html"
      },
      {
        "source": "/quiz",
        "destination": "/quiz.html"
      },
      {
        "source": "/contacts",
        "destination": "/contacts.html"
      },
      {
        "source": "/feedback",
        "destination": "/feedback.html"
      },
      {
        "source": "/profile",
        "destination": "/profile.html"
      },
      {
        "source": "/offline",
        "destination": "/offline.html"
      },
      {
        "source": "/offer",
        "destination": "/offer.html"
      }
    ]
  }
}
